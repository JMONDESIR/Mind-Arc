---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import NewsSection from "../components/NewsSection.astro";
---

<BaseLayout>
  <Hero
    title="news"
    tagline="Cinematic design. Technical discipline."
    bgUrl="/images/hero-news.jpg"
    primaryCta={null}
    secondaryCta={null}
    height="50vh"
    overlayOpacity={0.7}
    align="left"
  />

  <main style="padding: 2rem;">
    <NewsSection />
  </main>
</BaseLayout>

