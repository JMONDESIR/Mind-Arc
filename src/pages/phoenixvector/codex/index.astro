---
const codexSections = [
  {
    label: 'Overview',
    href: '/phoenixvector/codex',
    status: 'Online',
  },
  {
    label: 'Aurelia System',
    href: '/phoenixvector/codex/aurelia-system',
    status: 'Queued',
  },
  {
    label: 'Neo Terra',
    href: '/phoenixvector/codex/neo-terra',
    status: 'Queued',
  },
  {
    label: 'Selara',
    href: '/phoenixvector/codex/selara',
    status: 'Queued',
  },
  {
    label: 'Ironreach',
    href: '/phoenixvector/codex/ironreach',
    status: 'Queued',
  },
  {
    label: 'Fighters',
    href: '/phoenixvector/codex/fighters',
    status: 'Queued',
  },
  {
    label: 'Armaments',
    href: '/phoenixvector/codex/armaments',
    status: 'Queued',
  },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Phoenix Vector Codex</title>
    <meta
      name="description"
      content="Access the Phoenix Vector Codex and explore the Aurelia System, Neo Terra, Selara, and the growing archive of the Phoenix Vector universe."
    />

    <style>
      :root {
        --bg: #05080c;
        --bg-soft: rgba(10, 17, 24, 0.84);
        --panel: rgba(10, 17, 24, 0.72);
        --panel-strong: rgba(8, 14, 20, 0.92);
        --border: rgba(103, 232, 253, 0.18);
        --border-strong: rgba(103, 232, 253, 0.34);
        --text: #e6f6fb;
        --muted: rgba(230, 246, 251, 0.68);
        --accent: #67e8fd;
        --accent-soft: rgba(103, 232, 253, 0.12);
        --success: #86efac;
        --shadow: 0 24px 80px rgba(0, 0, 0, 0.45);
        --radius-xl: 28px;
        --radius-lg: 22px;
        --radius-md: 16px;
        --sidebar-width: 290px;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        min-height: 100vh;
        color: var(--text);
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background:
          radial-gradient(circle at top, rgba(103, 232, 253, 0.08), transparent 28%),
          linear-gradient(180deg, #071018 0%, var(--bg) 100%);
        overflow-x: hidden;
      }

      body::before,
      body::after {
        content: '';
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: -1;
      }

      body::before {
        background-image:
          linear-gradient(rgba(103, 232, 253, 0.04) 1px, transparent 1px),
          linear-gradient(90deg, rgba(103, 232, 253, 0.04) 1px, transparent 1px);
        background-size: 48px 48px;
        mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.9), transparent 95%);
      }

      body::after {
        background: linear-gradient(180deg, transparent 0%, rgba(0, 0, 0, 0.18) 100%);
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .shell {
        width: min(1400px, calc(100% - 32px));
        margin: 0 auto;
        padding: 24px 0 40px;
      }

.topbar {
  position: sticky;
  top: 12px;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  margin-bottom: 18px;
  padding: 14px 18px;
  border: 1px solid var(--border);
  border-radius: 18px;
  background: rgba(6, 12, 18, 0.72);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  box-shadow: var(--shadow);
}

      .eyebrow {
        margin: 0;
        color: var(--accent);
        font-family: "IBM Plex Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 0.76rem;
        letter-spacing: 0.26em;
        text-transform: uppercase;
      }

      .topbar-title {
        margin: 0.35rem 0 0;
        font-size: clamp(1.1rem, 2vw, 1.45rem);
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .topbar-meta {
        display: flex;
        flex-wrap: wrap;
        justify-content: flex-end;
        gap: 0.75rem;
        color: var(--muted);
        font-family: "IBM Plex Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 0.76rem;
        text-transform: uppercase;
      }

      .status-pill {
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.4rem 0.7rem;
        border: 1px solid var(--border);
        border-radius: 999px;
        background: rgba(103, 232, 253, 0.06);
      }

      .status-pill::before {
        content: '';
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--accent);
        box-shadow: 0 0 12px rgba(103, 232, 253, 0.9);
      }

      .layout {
        display: grid;
        grid-template-columns: var(--sidebar-width) minmax(0, 1fr);
        gap: 18px;
        align-items: start;
      }

      .sidebar {
        position: sticky;
        top: 24px;
        border: 1px solid var(--border);
        border-radius: var(--radius-xl);
        background: linear-gradient(180deg, rgba(9, 16, 22, 0.96) 0%, rgba(7, 12, 18, 0.92) 100%);
        box-shadow: var(--shadow);
        overflow: hidden;
      }

      .sidebar-head {
        padding: 1.4rem 1.25rem 1rem;
        border-bottom: 1px solid var(--border);
        background: linear-gradient(180deg, rgba(103, 232, 253, 0.08) 0%, transparent 100%);
      }

      .sidebar-head h2,
      .sidebar-head p {
        margin: 0;
      }

      .sidebar-head h2 {
        font-size: 1rem;
        text-transform: uppercase;
        letter-spacing: 0.14em;
      }

      .sidebar-head p {
        margin-top: 0.6rem;
        color: var(--muted);
        line-height: 1.6;
        font-size: 0.95rem;
      }

      .nav-group {
        padding: 1rem;
      }

      .nav-label {
        margin: 0 0 0.75rem;
        color: var(--accent);
        font-family: "IBM Plex Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 0.74rem;
        letter-spacing: 0.22em;
        text-transform: uppercase;
      }

      .nav-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: grid;
        gap: 0.65rem;
      }

      .nav-link {
        display: grid;
        gap: 0.2rem;
        padding: 0.9rem 0.95rem;
        border: 1px solid transparent;
        border-radius: 14px;
        background: transparent;
        transition:
          border-color 0.25s ease,
          background-color 0.25s ease,
          transform 0.25s ease,
          box-shadow 0.25s ease;
      }

      .nav-link:hover,
      .nav-link:focus-visible {
        border-color: var(--border-strong);
        background: rgba(103, 232, 253, 0.06);
        transform: translateX(4px);
        box-shadow: 0 0 0 1px rgba(103, 232, 253, 0.05) inset;
        outline: none;
      }

      .nav-link.active {
        border-color: var(--border-strong);
        background:
          linear-gradient(90deg, rgba(103, 232, 253, 0.18) 0%, rgba(103, 232, 253, 0.04) 85%),
          rgba(103, 232, 253, 0.06);
        box-shadow:
          inset 3px 0 0 var(--accent),
          0 0 0 1px rgba(103, 232, 253, 0.05);
      }

      .nav-link-title {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        font-size: 0.97rem;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }

      .nav-link-status {
        color: var(--muted);
        font-family: "IBM Plex Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 0.72rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .nav-link-copy {
        color: var(--muted);
        font-size: 0.88rem;
        line-height: 1.4;
      }

      .content {
        position: relative;
        border: 1px solid var(--border);
        border-radius: var(--radius-xl);
        background:
          linear-gradient(180deg, rgba(11, 18, 26, 0.94) 0%, rgba(7, 11, 16, 0.92) 100%);
        box-shadow: var(--shadow);
        overflow: hidden;
      }

      .content::before {
        content: '';
        position: absolute;
        inset: 0;
        background:
          linear-gradient(135deg, rgba(103, 232, 253, 0.08), transparent 35%),
          linear-gradient(180deg, transparent, rgba(103, 232, 253, 0.02));
        pointer-events: none;
      }

      .content-inner {
        position: relative;
        padding: clamp(1.4rem, 2vw, 2rem);
      }

      .content-head {
        display: grid;
        grid-template-columns: minmax(0, 1.4fr) minmax(280px, 0.8fr);
        gap: 1rem;
        padding-bottom: 1.4rem;
        border-bottom: 1px solid var(--border);
      }

      .content-head h1,
      .content-head p {
        margin: 0;
      }

      .content-head h1 {
        margin-top: 0.6rem;
        font-size: clamp(2rem, 4vw, 3.5rem);
        line-height: 0.95;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .lede {
        margin-top: 1rem !important;
        max-width: 62ch;
        color: var(--muted);
        font-size: 1.05rem;
        line-height: 1.8;
      }

      .meta-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.9rem;
      }

      .meta-card {
        padding: 1rem;
        border: 1px solid var(--border);
        border-radius: 18px;
        background: rgba(103, 232, 253, 0.04);
      }

      .meta-card span,
      .meta-card strong {
        display: block;
      }

      .meta-card span {
        color: var(--muted);
        font-family: "IBM Plex Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 0.72rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
      }

      .meta-card strong {
        margin-top: 0.55rem;
        font-size: 1rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
      }

      .display-module {
        margin-top: 1.4rem;
        padding: clamp(1.2rem, 2vw, 1.6rem);
        border: 1px solid var(--border-strong);
        border-radius: var(--radius-lg);
        background:
          radial-gradient(circle at top right, rgba(103, 232, 253, 0.12), transparent 25%),
          linear-gradient(180deg, rgba(9, 16, 22, 0.95), rgba(7, 11, 16, 0.88));
      }

      .display-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.1fr) minmax(280px, 0.9fr);
        gap: 1.2rem;
        align-items: stretch;
      }

      .starfield {
        position: relative;
        min-height: 360px;
        border: 1px solid var(--border);
        border-radius: 24px;
        overflow: hidden;
        background:
          radial-gradient(circle at 32% 42%, rgba(255, 207, 107, 0.95), rgba(255, 207, 107, 0.08) 11%, transparent 18%),
          radial-gradient(circle at 45% 40%, rgba(245, 132, 68, 0.85), rgba(245, 132, 68, 0.08) 8%, transparent 15%),
          radial-gradient(circle at 70% 25%, rgba(120, 216, 255, 0.45), rgba(120, 216, 255, 0.08) 8%, transparent 16%),
          radial-gradient(circle at 68% 58%, rgba(45, 77, 120, 0.75), rgba(45, 77, 120, 0.18) 18%, transparent 32%),
          linear-gradient(180deg, #04070b 0%, #07111c 100%);
      }

      .starfield::before,
      .starfield::after {
        content: '';
        position: absolute;
        inset: 0;
      }

      .starfield::before {
        background-image:
          radial-gradient(circle at 14% 22%, rgba(255, 255, 255, 0.9) 0 1px, transparent 2px),
          radial-gradient(circle at 24% 76%, rgba(255, 255, 255, 0.8) 0 1px, transparent 2px),
          radial-gradient(circle at 56% 15%, rgba(255, 255, 255, 0.8) 0 1px, transparent 2px),
          radial-gradient(circle at 82% 18%, rgba(255, 255, 255, 0.8) 0 1px, transparent 2px),
          radial-gradient(circle at 76% 72%, rgba(255, 255, 255, 0.75) 0 1px, transparent 2px),
          radial-gradient(circle at 62% 84%, rgba(255, 255, 255, 0.7) 0 1px, transparent 2px),
          radial-gradient(circle at 38% 86%, rgba(255, 255, 255, 0.7) 0 1px, transparent 2px),
          radial-gradient(circle at 90% 48%, rgba(255, 255, 255, 0.65) 0 1px, transparent 2px),
          radial-gradient(circle at 10% 55%, rgba(255, 255, 255, 0.65) 0 1px, transparent 2px),
          radial-gradient(circle at 48% 48%, rgba(255, 255, 255, 0.6) 0 1px, transparent 2px);
      }

      .starfield::after {
        background:
          linear-gradient(transparent 0 94%, rgba(103, 232, 253, 0.05) 94% 100%),
          linear-gradient(90deg, transparent 0 94%, rgba(103, 232, 253, 0.05) 94% 100%);
        background-size: 100% 32px, 32px 100%;
        mix-blend-mode: screen;
      }

      .orbit {
        position: absolute;
        border: 1px solid rgba(103, 232, 253, 0.18);
        border-radius: 999px;
      }

      .orbit.one {
        width: 180px;
        height: 180px;
        left: 22%;
        top: 17%;
      }

      .orbit.two {
        width: 300px;
        height: 300px;
        left: 28%;
        top: 8%;
      }

      .planet {
        position: absolute;
        width: 84px;
        height: 84px;
        right: 16%;
        bottom: 15%;
        border-radius: 50%;
        background:
          radial-gradient(circle at 35% 32%, rgba(147, 221, 255, 0.95), rgba(58, 97, 143, 0.92) 48%, rgba(14, 24, 40, 0.96) 100%);
        box-shadow:
          0 0 0 10px rgba(103, 232, 253, 0.06),
          0 0 38px rgba(103, 232, 253, 0.12);
      }

      .planet::after {
        content: 'Neo Terra';
        position: absolute;
        left: 50%;
        bottom: -2.15rem;
        transform: translateX(-50%);
        white-space: nowrap;
        color: var(--accent);
        font-family: "IBM Plex Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 0.7rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
      }

      .module-copy {
        display: grid;
        gap: 1rem;
      }

      .module-copy h2,
      .module-copy p {
        margin: 0;
      }

      .module-copy h2 {
        font-size: clamp(1.25rem, 2vw, 1.9rem);
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .module-copy p {
        color: var(--muted);
        line-height: 1.8;
      }

      .card-grid {
        margin-top: 1.3rem;
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1rem;
      }

      .data-card {
        padding: 1rem;
        border: 1px solid var(--border);
        border-radius: 18px;
        background: rgba(103, 232, 253, 0.04);
      }

      .data-card small,
      .data-card strong,
      .data-card p {
        display: block;
        margin: 0;
      }

      .data-card small {
        color: var(--accent);
        font-family: "IBM Plex Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 0.7rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
      }

      .data-card strong {
        margin-top: 0.65rem;
        font-size: 1rem;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }

      .data-card p {
        margin-top: 0.55rem;
        color: var(--muted);
        line-height: 1.65;
        font-size: 0.95rem;
      }

      .section-grid {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(280px, 0.8fr);
        gap: 1rem;
        margin-top: 1.4rem;
      }

      .section-card {
        padding: 1.2rem;
        border: 1px solid var(--border);
        border-radius: 20px;
        background: rgba(255, 255, 255, 0.02);
      }

      .section-card h3,
      .section-card p,
      .section-card ul {
        margin: 0;
      }

      .section-card h3 {
        color: var(--accent);
        font-size: 0.82rem;
        font-family: "IBM Plex Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
        letter-spacing: 0.2em;
        text-transform: uppercase;
      }

      .section-card p {
        margin-top: 0.9rem;
        color: var(--muted);
        line-height: 1.8;
      }

      .section-card ul {
        margin-top: 0.9rem;
        padding-left: 1rem;
        color: var(--muted);
        line-height: 1.8;
      }

      .cta-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.85rem;
        margin-top: 1.6rem;
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 48px;
        padding: 0.8rem 1.15rem;
        border-radius: 999px;
        border: 1px solid var(--border-strong);
        font-size: 0.92rem;
        font-weight: 600;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        transition:
          transform 0.25s ease,
          background-color 0.25s ease,
          border-color 0.25s ease;
      }

      .button:hover,
      .button:focus-visible {
        transform: translateY(-2px);
        outline: none;
      }

      .button.primary {
        background: linear-gradient(180deg, rgba(103, 232, 253, 0.22), rgba(103, 232, 253, 0.1));
      }

      .button.secondary {
        background: transparent;
      }

      .mobile-rail {
        display: none;
        margin-bottom: 18px;
        padding: 0.9rem 1rem;
        border: 1px solid var(--border);
        border-radius: 18px;
        background: rgba(6, 12, 18, 0.75);
        box-shadow: var(--shadow);
      }

      .mobile-rail summary {
        cursor: pointer;
        list-style: none;
        font-size: 0.96rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .mobile-rail summary::-webkit-details-marker {
        display: none;
      }

      .mobile-rail ul {
        list-style: none;
        margin: 0.9rem 0 0;
        padding: 0;
        display: grid;
        gap: 0.7rem;
      }

      .mobile-rail a {
        display: block;
        padding: 0.8rem 0.95rem;
        border: 1px solid var(--border);
        border-radius: 14px;
        color: var(--muted);
      }

      @media (max-width: 1100px) {
        .content-head,
        .display-grid,
        .section-grid {
          grid-template-columns: 1fr;
        }

        .card-grid {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 920px) {
        .shell {
          width: min(100% - 24px, 1400px);
          padding-top: 16px;
        }

        .layout {
          grid-template-columns: 1fr;
        }

        .sidebar {
          display: none;
        }

        .mobile-rail {
          display: block;
        }

        .topbar {
          flex-direction: column;
          align-items: flex-start;
        }

        .topbar-meta {
          justify-content: flex-start;
        }
      }

      @media (max-width: 640px) {
        .meta-grid {
          grid-template-columns: 1fr;
        }

        .content-inner {
          padding: 1rem;
        }

        .display-module,
        .section-card,
        .meta-card,
        .data-card {
          border-radius: 18px;
        }

        .starfield {
          min-height: 280px;
        }
      }
    </style>
  </head>

  <body>
    <main class="shell">
      <header class="topbar" aria-label="Phoenix Vector archive status">
        <div>
          <p class="eyebrow">Phoenix Vector Archive</p>
          <h1 class="topbar-title">Codex Access Node // Aurelia Database</h1>
        </div>

        <div class="topbar-meta">
          <a href="https://mindarcgames.com" class="status-pill" style="text-decoration:none">MindArcGames.com</a>
          <span class="status-pill">Link Status: Active</span>
          <span class="status-pill">Node: Mind Arc Network</span>
        </div>
      </header>

      <details class="mobile-rail">
        <summary>Codex Navigation</summary>
        <ul>
          {codexSections.map((section) => (
            <li>
              <a href={section.href}>{section.label}</a>
            </li>
          ))}
        </ul>
      </details>

      <section class="layout">
        <aside class="sidebar" aria-label="Codex navigation">
          <div class="sidebar-head">
            <h2>Records</h2>

          </div>

          <div class="nav-group">
            <ul class="nav-list">
              {codexSections.map((section) => (
                <li>
                  <a
                    href={section.href}
                    class:list={['nav-link', section.href === '/phoenixvector/codex' && 'active']}
                    aria-current={section.href === '/phoenixvector/codex' ? 'page' : undefined}
                  >
                    <span class="nav-link-title">
                      <span>{section.label}</span>
                      <span class="nav-link-status">{section.status}</span>
                    </span>
                    <span class="nav-link-copy">
                      {section.href === '/phoenixvector/codex'
                        ? 'Entry point to the Phoenix Vector world archive.'
                        : 'New record path prepared for expansion.'}
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </aside>

        <article class="content">
          <div class="content-inner">
            <div class="content-head">
              <div>
                <p class="eyebrow">Archive Entry // 00</p>
                <h1>Phoenix Vector Codex</h1>
                <p class="lede">
                  Welcome to the in-universe archive for <strong>Phoenix Vector</strong>. This codex is designed as a tactical knowledge terminal, housing the worlds, installations, machines, and history that define the Aurelia System.
                </p>
              </div>

              <div class="meta-grid" aria-label="Archive metadata">
                <div class="meta-card">
                  <span>Classification</span>
                  <strong>Public Archive</strong>
                </div>
                <div class="meta-card">
                  <span>Primary Theater</span>
                  <strong>Aurelia System</strong>
                </div>
                <div class="meta-card">
                  <span>Signal State</span>
                  <strong>Stable Uplink</strong>
                </div>
                <div class="meta-card">
                  <span>Record Expansion</span>
                  <strong>In Progress</strong>
                </div>
              </div>
            </div>

            <section class="display-module" aria-label="Featured archive preview">
              <div class="display-grid">
                <div class="starfield">
                  <div class="orbit one"></div>
                  <div class="orbit two"></div>
                  <div class="planet"></div>
                </div>

                <div class="module-copy">
                  <div>
                    <p class="eyebrow">Featured Record</p>
                    <h2>The Aurelia System</h2>
                  </div>
                  <p>
