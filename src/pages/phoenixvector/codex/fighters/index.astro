---
import NTDCTerminal from "../../../../components/codex/NTDCTerminal.astro";
import fighters from "../../../../data/fighters.json";

import "../../../../styles/codex-entries.css";
import "../../../../styles/codex-fighters.css";
---

<NTDCTerminal
  title="Fighters"
  subtitle="Combat Craft Archive"
  status="Status: Declassified"
>
  <section class="fighter-archive">
    <div class="fighter-grid" aria-label="Fighter archive entries">
      {
        fighters.map((fighter) => (
          <a class="fighter-card" href={fighter.href}>
            <img
              class="fighter-card__image"
              src={fighter.image}
              alt={`${fighter.name} fighter craft`}
              loading="lazy"
            />

            <div class="fighter-card__shade" />

            <div class="fighter-card__content">
              <span class="fighter-card__meta">
                {fighter.designation} / {fighter.class} Class
              </span>

              <h2>{fighter.name}</h2>

              <span class="fighter-card__status">{fighter.status}</span>
            </div>
          </a>
        ))
      }
    </div>
  </section>
</NTDCTerminal>
