---
import Layout from "../layouts/BaseLayout.astro";
---

<Layout title="About | Mind Arc Games">
  <main class="about-page">
    <div class="about-shell">
      <section class="hero">
        <p class="eyebrow">Mind Arc Games</p>
        <h1>About</h1>
        <p class="hero-subtitle">
          Independent sci-fi game development with a focus on atmosphere, identity,
          and immersive worlds.
        </p>
      </section>

      <section class="panel intro-panel">
        <div class="panel-header">
          <p class="section-kicker">Studio</p>
          <h2>Who We Are</h2>
        </div>

        <p>
          <strong>Mind Arc Games</strong> is an independent creative studio dedicated
          to building science-fiction game experiences with strong visual identity,
          cinematic atmosphere, and memorable worldbuilding.
        </p>

        <p>
          Our work is driven by a love for futuristic design, spacefaring conflict,
          immersive tone, and gameplay that feels sharp, focused, and intentional.
        </p>
      </section>

      <section class="panel mission-panel">
        <div class="panel-header">
          <p class="section-kicker">Vision</p>
          <h2>Our Mission</h2>
        </div>

        <p>
          Mind Arc Games exists to create worlds that feel larger than the screen:
          places with history, tension, mystery, and style. We believe that strong
          atmosphere and clear artistic direction can make even a compact experience
          feel vast.
        </p>

        <p>
          Our goal is to develop games that combine arcade-inspired energy with a
          deeper sense of universe, identity, and momentum.
        </p>
      </section>

      <section class="panel feature-panel">
        <div class="feature-grid">
          <div class="feature-copy">
            <p class="section-kicker">Featured Project</p>
            <h2>Phoenix Vector</h2>

            <p>
              <strong>Phoenix Vector</strong> is the flagship project of Mind Arc
              Games: a fast-paced side-scrolling sci-fi combat experience set in a
              larger universe of conflict, drifting stations, war-torn frontiers, and
              luminous celestial horizons.
            </p>

            <p>
              Built around precise action and a bold visual identity, Phoenix Vector
              represents the studio’s commitment to creating games that feel both
              immediate and expansive.
            </p>

            <div class="feature-actions">
              <a href="/games" class="btn btn-primary">View Games</a>
              <a href="/contact" class="btn btn-secondary">Contact</a>
            </div>
          </div>

          <div class="feature-card">
            <div class="feature-card-inner">
              <p class="feature-label">Creative Direction</p>
              <h3>Atmosphere. Precision. Worldbuilding.</h3>
              <p>
                Every project is shaped around a clear mood, a strong visual language,
                and the feeling that there is always more beyond the horizon.
              </p>
            </div>
          </div>
        </div>
      </section>

      <section class="values-grid">
        <article class="info-card">
          <p class="section-kicker">Principle</p>
          <h3>Strong Identity</h3>
          <p>
            We believe games should have a distinct voice, not just in story, but in
            silhouette, color, atmosphere, and interface.
          </p>
        </article>

        <article class="info-card">
          <p class="section-kicker">Principle</p>
          <h3>Focused Design</h3>
          <p>
            We value clarity, responsiveness, and gameplay systems that feel polished,
            deliberate, and rewarding to master.
          </p>
        </article>

        <article class="info-card">
          <p class="section-kicker">Principle</p>
          <h3>Expanding Worlds</h3>
          <p>
            Our projects are built with the idea that a game can be more than a single
            experience. It can be a universe waiting to grow.
          </p>
        </article>
      </section>
    </div>
  </main>
</Layout>

<style>
  :root {
    --bg: #040814;
    --bg-soft: rgba(10, 18, 36, 0.82);
    --panel-border: rgba(103, 232, 249, 0.18);
    --text: #dbe7f5;
    --text-soft: #9fb2c9;
    --heading: #f8fbff;
    --cyan: #67e8f9;
    --cyan-strong: #22d3ee;
    --gold: #ffc857;
    --shadow: 0 24px 80px rgba(0, 0, 0, 0.45);
  }

  .about-page {
    position: relative;
    min-height: 100vh;
    padding: 5rem 1.25rem;
    background:
      radial-gradient(circle at top center, rgba(34, 211, 238, 0.12), transparent 28%),
      radial-gradient(circle at 20% 20%, rgba(255, 200, 87, 0.08), transparent 18%),
      linear-gradient(180deg, #081120 0%, #040814 55%, #02050d 100%);
    overflow: hidden;
  }

  .about-page::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
    background-size: 36px 36px;
    mask-image: linear-gradient(to bottom, rgba(0,0,0,0.45), rgba(0,0,0,0.08));
    pointer-events: none;
  }

  .about-shell {
    position: relative;
    z-index: 1;
    max-width: 1120px;
    margin: 0 auto;
  }

  .hero {
    text-align: center;
    margin-bottom: 2rem;
    padding: 2rem 0 1rem;
  }

  .eyebrow {
    margin: 0 0 0.75rem;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--cyan);
  }

  .hero h1 {
    margin: 0;
    font-size: clamp(2.75rem, 6vw, 4.75rem);
    line-height: 1;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--heading);
    text-shadow:
      0 0 18px rgba(103, 232, 249, 0.12),
      0 0 40px rgba(103, 232, 249, 0.08);
  }

  .hero-subtitle {
    max-width: 760px;
    margin: 1rem auto 0;
    font-size: 1.05rem;
    line-height: 1.9;
    color: var(--gold);
    letter-spacing: 0.04em;
  }

  .panel {
    position: relative;
    margin-bottom: 1.5rem;
    padding: 2rem;
    border: 1px solid var(--panel-border);
    border-radius: 22px;
    background:
      linear-gradient(180deg, rgba(14, 25, 47, 0.88), rgba(7, 13, 26, 0.94));
    box-shadow: var(--shadow);
    backdrop-filter: blur(10px);
  }

  .panel::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 22px;
    padding: 1px;
    background: linear-gradient(
      135deg,
      rgba(103, 232, 249, 0.35),
      rgba(255, 200, 87, 0.18),
      rgba(103, 232, 249, 0.1)
    );
    -webkit-mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
  }

  .panel-header {
    margin-bottom: 1rem;
  }

  .section-kicker {
    margin: 0 0 0.5rem;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold);
  }

  .panel h2,
  .info-card h3,
  .feature-card h3 {
    margin: 0;
    color: var(--heading);
    line-height: 1.1;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .panel h2 {
    font-size: clamp(1.6rem, 3vw, 2.25rem);
  }

  .panel p,
  .info-card p,
  .feature-card p {
    color: var(--text);
    line-height: 1.85;
    font-size: 1rem;
  }

  .feature-grid {
    display: grid;
    grid-template-columns: 1.35fr 0.85fr;
    gap: 1rem;
    align-items: stretch;
  }

  .feature-copy {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .feature-copy h2 {
    margin-bottom: 1rem;
  }

  .feature-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 1rem;
  }

  .feature-card {
    display: flex;
    min-height: 100%;
    border-radius: 20px;
    border: 1px solid rgba(103, 232, 249, 0.14);
    background:
      radial-gradient(circle at top right, rgba(103, 232, 249, 0.12), transparent 35%),
      linear-gradient(180deg, rgba(255,255,255,0.05), rgba(255,255,255,0.02));
    overflow: hidden;
  }

  .feature-card-inner {
    padding: 1.5rem;
    align-self: center;
  }

  .feature-label {
    margin: 0 0 0.75rem;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--cyan);
  }

  .feature-card h3 {
    margin-bottom: 1rem;
    font-size: 1.35rem;
  }

  .values-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .info-card {
    position: relative;
    padding: 1.5rem;
    border-radius: 20px;
    border: 1px solid rgba(103, 232, 249, 0.14);
    background:
      linear-gradient(180deg, rgba(14, 25, 47, 0.82), rgba(7, 13, 26, 0.9));
    box-shadow: 0 18px 50px rgba(0, 0, 0, 0.25);
    overflow: hidden;
  }

  .info-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at top right, rgba(103, 232, 249, 0.08), transparent 35%);
    pointer-events: none;
  }

  .info-card h3 {
    margin-bottom: 0.85rem;
    font-size: 1.2rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 180px;
    padding: 0.95rem 1.4rem;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 700;
    letter-spacing: 0.04em;
    transition:
      transform 0.2s ease,
      border-color 0.2s ease,
      box-shadow 0.2s ease,
      background 0.2s ease,
      color 0.2s ease;
  }

  .btn:hover {
    transform: translateY(-2px);
  }

  .btn-primary {
    color: #031018;
    background: linear-gradient(135deg, var(--cyan), #a5f3fc);
    box-shadow: 0 10px 30px rgba(103, 232, 249, 0.22);
  }

  .btn-primary:hover {
    box-shadow: 0 16px 34px rgba(103, 232, 249, 0.3);
  }

  .btn-secondary {
    color: var(--heading);
    border: 1px solid rgba(103, 232, 249, 0.22);
    background: rgba(255,255,255,0.03);
    backdrop-filter: blur(8px);
  }

  .btn-secondary:hover {
    border-color: rgba(103, 232, 249, 0.42);
    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.24);
  }

  @media (max-width: 900px) {
    .feature-grid {
      grid-template-columns: 1fr;
    }

    .values-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .about-page {
      padding: 3rem 1rem;
    }

    .panel {
      padding: 1.4rem;
      border-radius: 18px;
    }

    .panel::before {
      border-radius: 18px;
    }

    .feature-actions {
      flex-direction: column;
    }

    .btn {
      width: 100%;
      min-width: 0;
    }

    .info-card {
      padding: 1.25rem;
      border-radius: 18px;
    }

    .hero-subtitle {
      font-size: 0.98rem;
    }
  }
</style>
