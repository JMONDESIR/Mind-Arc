---
import Layout from "../layouts/BaseLayout.astro";
---

<Layout title="Contact | Mind Arc Games">
  <main class="contact-page">
    <div class="contact-shell">
      <section class="hero">
        <p class="eyebrow">Mind Arc Games</p>
        <h1>Contact</h1>
        <p class="hero-subtitle">Get in touch with Mind Arc Games</p>
      </section>

      <section class="contact-panel">
        <p>
          Questions, support requests, business inquiries, or feedback about
          <strong>Phoenix Vector</strong> are always welcome.
        </p>

        <p>
          If you need to reach us, use the contact details below and we’ll respond as
          soon as possible.
        </p>

        <div class="contact-grid">
          <article class="info-card">
            <h2>Email</h2>
            <p>The best way to reach us for general inquiries and support.</p>
            <p>
              <a href="mailto:contact@mindarcgames.com">contact@mindarcgames.com</a>
            </p>
          </article>

          <article class="info-card">
            <h2>Website</h2>
            <p>Visit the official Mind Arc Games website.</p>
            <p>
              <a href="https://mindarcgames.com" target="_blank" rel="noopener noreferrer">
                mindarcgames.com
              </a>
            </p>
          </article>

          <article class="info-card">
            <h2>Support</h2>
            <p>
              For gameplay issues, bug reports, account concerns, or technical
              questions related to <strong>Phoenix Vector</strong>, please email us
              with as much detail as possible.
            </p>
          </article>

          <article class="info-card">
            <h2>Business Inquiries</h2>
            <p>
              For partnerships, press, licensing, or other professional inquiries,
              please contact us by email and include a clear subject line so we can
              route your message properly.
            </p>
          </article>
        </div>
      </section>
    </div>
  </main>
</Layout>

<style>
  :root {
    --bg: #040814;
    --bg-soft: rgba(10, 18, 36, 0.82);
    --panel-border: rgba(103, 232, 249, 0.18);
    --text: #dbe7f5;
    --text-soft: #9fb2c9;
    --heading: #f8fbff;
    --cyan: #67e8f9;
    --cyan-strong: #22d3ee;
    --gold: #ffc857;
    --shadow: 0 24px 80px rgba(0, 0, 0, 0.45);
  }

  .contact-page {
    position: relative;
    min-height: 100vh;
    padding: 5rem 1.25rem;
    background:
      radial-gradient(circle at top center, rgba(34, 211, 238, 0.12), transparent 28%),
      radial-gradient(circle at 20% 20%, rgba(255, 200, 87, 0.08), transparent 18%),
      linear-gradient(180deg, #081120 0%, #040814 55%, #02050d 100%);
    overflow: hidden;
  }

  .contact-page::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
    background-size: 36px 36px;
    mask-image: linear-gradient(to bottom, rgba(0,0,0,0.45), rgba(0,0,0,0.08));
    pointer-events: none;
  }

  .contact-shell {
    position: relative;
    z-index: 1;
    max-width: 960px;
    margin: 0 auto;
  }

  .hero {
    text-align: center;
    margin-bottom: 2rem;
    padding: 1rem 0 0.5rem;
  }

  .eyebrow {
    margin: 0 0 0.75rem;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--cyan);
  }

  .hero h1 {
    margin: 0;
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    line-height: 1;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--heading);
    text-shadow:
      0 0 18px rgba(103, 232, 249, 0.12),
      0 0 40px rgba(103, 232, 249, 0.08);
  }

  .hero-subtitle {
    margin: 1rem 0 0.35rem;
    font-size: 1.05rem;
    color: var(--gold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .contact-panel {
    position: relative;
    padding: 2rem;
    border: 1px solid var(--panel-border);
    border-radius: 22px;
    background:
      linear-gradient(180deg, rgba(14, 25, 47, 0.88), rgba(7, 13, 26, 0.94));
    box-shadow: var(--shadow);
    backdrop-filter: blur(10px);
  }

  .contact-panel::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 22px;
    padding: 1px;
    background: linear-gradient(
      135deg,
      rgba(103, 232, 249, 0.35),
      rgba(255, 200, 87, 0.18),
      rgba(103, 232, 249, 0.1)
    );
    -webkit-mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
  }

  .contact-panel p {
    color: var(--text);
    line-height: 1.85;
    font-size: 1rem;
    margin: 0 0 1rem;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .info-card {
    padding: 1.25rem;
    border-radius: 18px;
    border: 1px solid rgba(103, 232, 249, 0.14);
    background:
      linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.02));
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.04);
  }

  .info-card h2 {
    margin: 0 0 0.85rem;
    font-size: 1.15rem;
    line-height: 1.2;
    color: var(--heading);
    letter-spacing: 0.03em;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .info-card h2::before {
    content: "";
    display: inline-block;
    width: 22px;
    height: 2px;
    background: linear-gradient(90deg, var(--cyan), var(--gold));
    box-shadow: 0 0 10px rgba(103, 232, 249, 0.35);
  }

  .info-card a {
    color: var(--cyan);
    text-decoration: none;
    transition: color 0.2s ease, text-shadow 0.2s ease;
  }

  .info-card a:hover {
    color: #a5f3fc;
    text-shadow: 0 0 14px rgba(103, 232, 249, 0.22);
  }

  @media (max-width: 768px) {
    .contact-page {
      padding: 3rem 1rem;
    }

    .contact-panel {
      padding: 1.4rem;
      border-radius: 18px;
    }

    .contact-panel::before {
      border-radius: 18px;
    }

    .hero-subtitle {
      font-size: 0.95rem;
    }

    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>