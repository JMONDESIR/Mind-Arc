---
interface Props {
  title?: string;
}

const { title = "Codex Access Node // Aurelia Database" } = Astro.props;
---

<header class="topbar" aria-label="Phoenix Vector archive status">
  <div>
    <p class="eyebrow">Phoenix Vector Archive</p>
    <h1 class="topbar-title">{title}</h1>
  </div>

  <div class="topbar-meta">
    <a href="https://mindarcgames.com" class="status-pill">
      MindArcGames.com
    </a>

    <span class="status-pill">
      Link Status: Active
    </span>

    <span class="status-pill">
      Node: Mind Arc Network
    </span>
  </div>
</header>

<style>
.topbar {
  position: sticky;
  top: 12px;
  z-index: 1000;

  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;

  margin-bottom: 18px;
  padding: 14px 18px;

  border: 1px solid var(--border);
  border-radius: 18px;

  background: rgba(6, 12, 18, 0.88);

  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);

  box-shadow: var(--shadow);
}

.eyebrow {
  margin: 0;
  color: var(--accent);
  font-family: "IBM Plex Mono", monospace;
  font-size: 0.76rem;
  letter-spacing: 0.26em;
  text-transform: uppercase;
}

.topbar-title {
  margin: 0.35rem 0 0;
  font-size: clamp(1.1rem, 2vw, 1.45rem);
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.topbar-meta {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 0.75rem;

  color: var(--muted);

  font-family: "IBM Plex Mono", monospace;
  font-size: 0.76rem;
  text-transform: uppercase;
}

.status-pill {
  display: inline-flex;
  align-items: center;
  gap: 0.45rem;

  padding: 0.4rem 0.7rem;

  border: 1px solid var(--border);
  border-radius: 999px;

  background: rgba(103, 232, 253, 0.06);

  cursor: pointer;

  text-decoration: none;
  color: inherit;
}

.status-pill::before {
  content: "";

  width: 8px;
  height: 8px;

  border-radius: 50%;

  background: var(--accent);

  box-shadow: 0 0 12px rgba(103, 232, 253, 0.9);
}

/* Mobile */

@media (max-width: 920px) {
  .topbar {
    flex-direction: column;
    align-items: flex-start;
  }

  .topbar-meta {
    justify-content: flex-start;
  }
}
</style>