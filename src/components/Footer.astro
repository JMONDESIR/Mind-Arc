<style>
  .footer {
    width: 100%;
    padding: 1rem 0;
    /* theming: translucent surface w/ blur */
    background: color-mix(in oklab, var(--surface) 85%, transparent);
    backdrop-filter: blur(8px);
    color: var(--text);
    text-align: center;
    font-size: 0.9rem;
    border-top: 1px solid var(--border);
    position: fixed;
    bottom: 0;
    left: 0;
    transition:
      background-color 0.25s ease,
      border-color 0.25s ease,
      color 0.25s ease;
  }

  .footer strong {
    color: var(--accent); /* Mind Arc accent in both themes */
  }

  .footer-subtext {
    font-size: 0.75rem;
    color: color-mix(
      in oklab,
      var(--text) 70%,
      transparent
    ); /* subtle dim text */
    margin-top: 0.25rem;
  }

  /* Optional: if you have very vibrant backgrounds, add a soft inner top edge */
