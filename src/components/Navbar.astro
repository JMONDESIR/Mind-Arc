---
<style>
nav {
  width: 100%;
  max-width: 1200px;
  margin: 0 auto;
  padding: 1% 4%;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-sizing: border-box;
  background-color: rgb(47, 16, 105);
}


/* Increase vertical padding to add ~10px height */
.nav-container {
  display: grid;
  grid-template-columns: 1fr auto;
  grid-template-areas: "center toggle";
  align-items: center;
  padding: 1.625rem 2rem;  /* increased from 1rem to 1.625rem */
  max-width: 1200px;
  margin: 0 auto;
  width: 100%;
  position: relative;
}

/* Default: show nav links horizontally on large screens */
/* On large screens */
.nav-links {
  display: flex;
  gap: 1.5rem; /* controls spacing between links */
  align-items: center;
  justify-content: center;
  background-color: transparent;
  position: static;
  padding: 0;
  flex-direction: row;
  width: auto;
  z-index: auto;
}

.nav-links a {
  padding: 0.75rem 1.5rem; /* more horizontal padding */
  text-decoration: none;
  text-align: center;
  color: white;
  border-bottom: none;
  width: auto;
}

.nav-links a:hover {
  color: #ffd700;
}

.menu-toggle {
  display: none;
}

.hamburger {
  display: none;
  grid-area: toggle;
  justify-self: end;
  flex-direction: column;
  gap: 5px;
  cursor: pointer;
}

.hamburger span {
  width: 25px;
  height: 3px;
  background-color: white;
  border-radius: 3px;
}

/* Mobile styles */
@media (max-width: 768px) {
  /* Hide nav links by default on mobile */
  .nav-links {
    display: none;
    flex-direction: column;
    align-items: center;
    background-color: #222;
    padding: 1rem 0;
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    z-index: 99;
    width: 100%;
  }

  /* Show nav links when toggled */
  .menu-toggle:checked ~ .nav-links {
    display: flex;
  }

  .nav-links a {
    padding: 0.75rem 1.5rem;
    width: 100%;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    text-align: center;
  }

  .hamburger {
    display: flex;
  }

  .nav-container {
  grid-template-columns: 1fr auto;
  padding: 10px 5px;
}

}

</style>

<nav>
  <div class="nav-container">
    <input type="checkbox" id="menu-toggle" class="menu-toggle" />
    <label for="menu-toggle" class="hamburger" aria-label="Toggle menu">
      <span></span>
      <span></span>
      <span></span>
    </label>

    <div class="nav-links">
      <a href="/">Home</a>
      <a href="/about">Games</a>
      <a href="/projects">About</a>
      <a href="/contact">Contact</a>
    </div>
  </div>
</nav>
