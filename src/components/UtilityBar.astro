<style>
  .utility-bar {
    position: sticky;
    top: 0;
    z-index: 1000;

    display: flex;
    align-items: center;
    justify-content: space-between;
    position: sticky;
    padding: 0.6rem 2rem;

    background-color: color-mix(in oklab, var(--surface) 95%, transparent);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border);

    color: var(--text);
    font-size: 0.85rem;
    font-family: sans-serif;
    min-height: 60px;
  }

  .utility-left {
    display: flex;
    align-items: center;
    position: relative;
    z-index: 2;
  }

  .logo {
    display: flex;
    align-items: center;
  }

  .logo a {
    display: inline-flex;
    align-items: center;
  }

  .logo img {
    display: block;
    height: 24px;
    width: 200px;
    object-fit: contain;
    transition:
      transform 0.2s ease,
      opacity 0.2s ease;
  }

  .logo:hover img {
    transform: scale(1.03);
    opacity: 0.9;
  }

  .utility-nav {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    z-index: 1;
  }

  .nav-link {
    font-family: "Michroma", sans-serif;
    font-size: 0.8rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--text);
    position: relative;
    white-space: nowrap;
    transition: color 0.2s ease;
  }

  .nav-link:hover {
    color: var(--accent);
  }

  .nav-link::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -4px;
    width: 0%;
    height: 1px;
    background: var(--accent);
    transition: width 0.25s ease;
  }

  .nav-link:hover::after {
    width: 100%;
  }

  .utility-right {
    display: flex;
    align-items: center;
    gap: 1rem;
    position: relative;
    z-index: 2;
  }

  .utility-link,
  .theme-toggle {
    color: var(--text);
    text-decoration: none;
    transition:
      color 0.2s ease,
      opacity 0.2s ease,
      transform 0.2s ease;
  }

  .utility-link:hover,
  .theme-toggle:hover {
    color: var(--accent);
  }

  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    border: 1px solid var(--border);
    background: color-mix(in oklab, var(--surface) 70%, transparent);
    cursor: pointer;
    transition:
      background-color 0.25s ease,
      transform 0.25s ease,
      box-shadow 0.25s ease;
  }

  :root[data-theme="dark"] .theme-toggle {
    background: var(--text);
    color: var(--bg);
  }

  :root[data-theme="light"] .theme-toggle {
    background: var(--text);
    color: var(--bg);
  }

  .theme-toggle:hover {
    transform: translateY(-1px);
    box-shadow: 0 0 8px color-mix(in oklab, var(--accent) 30%, transparent);
  }

  .theme-icon {
    width: 18px;
    height: 18px;
    color: currentColor;
    transition: color 0.3s ease;
  }

  @media (max-width: 900px) {
    .utility-nav {
      gap: 1.35rem;
    }

    .nav-link {
      font-size: 0.82rem;
      letter-spacing: 0.1em;
    }

    .logo img {
      width: 170px;
      height: auto;
    }
  }

  @media (max-width: 768px) {
    .utility-bar {
      position: sticky;
      display: grid;
      grid-template-columns: 1fr;
      grid-template-rows: auto auto auto;
      justify-items: center;
      text-align: center;
      padding: 0.75rem 1rem;
      gap: 0.6rem;
      min-height: auto;
    }

    .utility-nav {
      position: static;
      left: auto;
      transform: none;
      gap: 1.5rem;
      flex-wrap: wrap;
      order: 2;
    }

    .utility-left,
    .utility-right {
      z-index: auto;
    }

    .utility-right {
      order: 3;
      justify-content: center;
      flex-wrap: wrap;
    }

    .utility-left {
      order: 1;
      justify-content: center;
    }

    .logo img {
      width: 170px;
      height: auto;
    }
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>

<div class="utility-bar">
  <div class="utility-left">
    <div class="logo">
      <a href="/" class="utility-link" aria-label="Go to homepage">
        <img src="/images/mindarcNoplanelogo.png" alt="Mind Arc Logo" />
      </a>
    </div>
  </div>

  <nav class="utility-nav" aria-label="Primary">
    <a href="/about" class="nav-link">About</a>
    <a href="/games" class="nav-link">Games</a>
    <a href="/contact" class="nav-link">Contact</a>
  </nav>

  <div class="utility-right">
    <a href="#" class="utility-link">Login</a>

    <button
      type="button"
      class="theme-toggle"
      aria-label="Toggle color theme"
      aria-pressed="false"
      onclick="
        (function(){
          const r = document.documentElement;
          const cur = r.getAttribute('data-theme') || 'light';
          const next = cur === 'dark' ? 'light' : 'dark';
          r.setAttribute('data-theme', next);
          localStorage.setItem('ma-theme', next);
          event.currentTarget.setAttribute('aria-pressed', String(next === 'dark'));
        })()
      "
    >
      <svg
        class="theme-icon"
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="currentColor"
      >
        <path
          d="M12 4.75a.75.75 0 0 1 .75.75v1a.75.75 0 0 1-1.5 0v-1A.75.75 0 0 1 12 4.75ZM12 17.5a.75.75 0 0 1 .75.75v1a.75.75 0 0 1-1.5 0v-1a.75.75 0 0 1 .75-.75ZM7.47 6.53a.75.75 0 0 1 1.06 0l.71.71a.75.75 0 0 1-1.06 1.06l-.71-.71a.75.75 0 0 1 0-1.06ZM15.47 14.53a.75.75 0 0 1 1.06 0l.71.71a.75.75 0 1 1-1.06 1.06l-.71-.71a.75.75 0 0 1 0-1.06ZM4.75 12a.75.75 0 0 1 .75-.75h1a.75.75 0 0 1 0 1.5h-1A.75.75 0 0 1 4.75 12ZM17.5 12a.75.75 0 0 1 .75-.75h1a.75.75 0 0 1 0 1.5h-1a.75.75 0 0 1-.75-.75ZM7.47 17.47a.75.75 0 0 1 0-1.06l.71-.71a.75.75 0 0 1 1.06 1.06l-.71.71a.75.75 0 0 1-1.06 0ZM15.47 9.47a.75.75 0 0 1 0-1.06l.71-.71a.75.75 0 1 1 1.06 1.06l-.71.71a.75.75 0 0 1-1.06 0ZM12 8a4 4 0 1 0 0 8 4 4 0 0 0 0-8Z"
        ></path>
      </svg>
      <span class="sr-only">Toggle theme</span>
    </button>

    <a href="#" class="utility-link">v1.0.1</a>
  </div>
</div>
